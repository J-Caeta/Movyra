datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum EntityType {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum UserRole {
  OWNER // Dono / Administrador Geral
  TEACHER // Professor / Instrutor
  RECEPTION // Recepção / Administrativo
}

model Tenant {
  id         String     @id @default(uuid())
  name       String // Nome Fantasia ou Nome do Profissional
  entityType EntityType

  // Pessoa Física (PF)
  cpf  String? @unique
  cref String?

  // Pessoa Jurídica (PJ)
  cnpj        String? @unique
  razaoSocial String?

  // Segmentos ativos (Habilitam/desabilitam módulos)
  hasPersonal    Boolean @default(false)
  hasMartialArts Boolean @default(false)
  hasRunning     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  students Student[]
  expenses Expense[]
}

model User {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  email            String   @unique
  passwordHash     String
  role             UserRole @default(OWNER)
  isVerified       Boolean  @default(false)
  verificationCode String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum StudentStatus {
  EM_ABERTO
  ADIMPLENTE
  INADIMPLENTE
  INATIVO
}

model Student {
  id              String              @id @default(uuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String              @unique
  name            String
  email           String
  whatsapp        String?
  dueDay          Int
  plan            String
  value           Decimal             @db.Decimal(10, 2)
  status          StudentStatus       @default(EM_ABERTO)
  association     String // Ex: Personal, Lutas, Corrida
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  payments        Payment[]
  martialProgress MartialArtProgress? // Relacionamento opcional
}

enum PaymentType {
  RECORRENTE
  LONGO_PRAZO
  POS_PAGO
}

model Payment {
  id             String      @id @default(uuid())
  studentId      String
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  paymentDate    DateTime    @default(now())
  referenceMonth DateTime
  amount         Decimal     @db.Decimal(10, 2)
  status         String
  type           PaymentType @default(RECORRENTE)
  notes          String?
  createdAt      DateTime    @default(now())
}

enum ExpenseType {
  OPERACIONAL
  PESSOAL
}

model Expense {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date          DateTime    @default(now())
  category      String
  description   String
  type          ExpenseType
  value         Decimal     @db.Decimal(10, 2)
  paymentMethod String
  nature        String
  notes         String?
  createdAt     DateTime    @default(now())
}

model MartialArtProgress {
  id            String   @id @default(uuid())
  studentId     String   @unique
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  martialArt    String
  currentBelt   String
  degree        Int      @default(0)
  lastPromotion DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
